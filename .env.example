BOT_TOKEN=
ADMIN_IDS=
ADMIN_BACKUP_PASSWORD=
DEBUG=false

# Host run: use localhost. docker-compose overrides DATABASE_URL/REDIS_URL.
DATABASE_URL=postgresql+asyncpg://dotmath:CHANGEME@localhost:5432/dotmath
# Leave empty to use in-memory FSM storage (state lost on restart).
# In docker-compose this is overridden to redis://redis:6379/0 automatically.
REDIS_URL=

POSTGRES_USER=dotmath
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=dotmath
