BOT_TOKEN=
ADMIN_IDS=
ADMIN_BACKUP_PASSWORD=
DEBUG=false

# Docker: хост "postgres" — имя сервиса в docker-compose.yml
DATABASE_URL=postgresql+asyncpg://dotmath:CHANGEME@postgres:5432/dotmath

# Локальный запуск без Docker: используйте localhost вместо postgres
# DATABASE_URL=postgresql+asyncpg://dotmath:CHANGEME@localhost:5432/dotmath

POSTGRES_USER=dotmath
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=dotmath
